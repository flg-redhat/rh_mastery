#!/usr/bin/env bash
# Wrapper for rh_mastery.py — use: rh-mastery [ARGS...]
# Same as: python3 /path/to/rh_mastery.py [ARGS...]
# Examples: rh-mastery help | rh-mastery sync --ansible | rh-mastery -h

set -euo pipefail

# Follow symlinks so this works when installed as e.g. /usr/local/bin/rh-mastery -> /opt/rh-mastery/rh-mastery.
_script_real_dir() {
    local s="${BASH_SOURCE[0]:-$0}"
    while [[ -h "$s" ]]; do
        local d
        d="$(cd -P "$(dirname "$s")" && pwd)"
        s="$(readlink "$s")"
        [[ "$s" != /* ]] && s="${d}/${s}"
    done
    cd -P "$(dirname "$s")" && pwd
}
SCRIPT_DIR="$(_script_real_dir)"
PY_SCRIPT="${SCRIPT_DIR}/rh_mastery.py"

if [[ ! -f "$PY_SCRIPT" ]]; then
    echo "rh-mastery: cannot find rh_mastery.py next to this script (${SCRIPT_DIR})" >&2
    exit 1
fi

if command -v python3 >/dev/null 2>&1; then
    exec env RH_MASTERY_PROG=rh-mastery python3 "$PY_SCRIPT" "$@"
elif command -v python >/dev/null 2>&1; then
    exec env RH_MASTERY_PROG=rh-mastery python "$PY_SCRIPT" "$@"
else
    echo "rh-mastery: neither python3 nor python found in PATH" >&2
    exit 1
fi
